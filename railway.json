{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixpkgs": ["nodejs_20", "npm"]
        },
        "install": {
          "cmds": ["npm install"]
        },
        "build": {
          "cmds": []
        },
        "start": {
          "cmds": ["node server.js"]
        }
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
